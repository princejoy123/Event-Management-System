

model Event {
  id          String   @id @default(uuid())
  title       String
  description String
  location    String
  date        DateTime
  price       Float
  capacity    Int
  createdById String

  createdBy   User     @relation(fields: [createdById], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("events")
}